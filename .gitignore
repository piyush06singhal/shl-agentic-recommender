.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1248, the recommended pattern is to only check in Pipfile.
#   Pipfile.lock contains local paths and system-specific information and should be ignored.
# Pipfile.lock

# poetry
#   poetry.lock contains local paths and system-specific information and should be ignored.
# poetry.lock

# pdm
#   Similar to Pipfile.lock / poetry.lock, pdm.lock contains local paths and should be ignored.
# pdm.lock

# PEP 582; dependency directory created by pdm when running `pdm install`
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

